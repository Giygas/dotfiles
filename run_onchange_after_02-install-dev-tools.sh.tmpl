#!/usr/bin/env bash
# vi:set filetype=sh:

# ╭──────────────────────────────────────────────────────────╮
# │ install-dev-tools                                        │
# │                                                          │
# │ Installs packages that mise does not cover.              │
# │ On atomic Fedora, uses toolbox or distrobox (whichever   │
# │ is available) to keep the host clean.                     │
# │                                                          │
# │ Uses a sentinel file to track completion, since this     │
# │ script is run_onchange_ and could be re-triggered by     │
# │ edits. The sentinel is only written on full success.     │
# ╰──────────────────────────────────────────────────────────╯

OS="{{ .chezmoi.os }}"
HOME_DIR="{{ .chezmoi.homeDir }}"
USER_NAME=$(whoami)

echo "OS detected: $OS"
echo "User: $USER_NAME"
echo "Home directory: $HOME_DIR"

# -------------------------------
# Detect Linux package manager
# -------------------------------
detect_pkg_manager() {
    if command -v rpm-ostree &>/dev/null; then
        echo "rpm-ostree"
    elif command -v dnf &>/dev/null; then
        echo "dnf"
    elif command -v apt-get &>/dev/null; then
        echo "apt"
    elif command -v pacman &>/dev/null; then
        echo "pacman"
    else
        echo "unknown"
    fi
}

# Detect available container tool for atomic Fedora hosts.
# Toolbox is standard on Silverblue/Kinoite; distrobox ships on Bazzite.
detect_container_tool() {
    if command -v toolbox &>/dev/null; then
        echo "toolbox"
    elif command -v distrobox &>/dev/null; then
        echo "distrobox"
    else
        echo "none"
    fi
}

PKG_MANAGER=$(detect_pkg_manager)
echo "Package manager detected: $PKG_MANAGER"

# Interactive prompt
printf "Do you want to install development tools? (y/n) "
read -n 1 -r response
echo
if [[ ! "$response" =~ ^([yY])$ ]]; then
    echo "⏭️  Skipping dev tools installation"
    exit 0
fi

echo "🔧 Starting dev environment setup..."

# ╭──────────────────────────────────────────────────────────╮
# │ macOS                                                    │
# ╰──────────────────────────────────────────────────────────╯
if [[ "$OS" == "darwin" ]]; then
    echo "📦 Setting up macOS dev environment..."

    if ! command -v brew &>/dev/null; then
        echo "Installing Homebrew..."
        /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    fi

    brew install \
        cocoapods colima docker \
        ffmpeg ghostscript imagemagick \
        gnupg icu4c@76 \
        mongosh pinentry-mac plow \
        luarocks

# ╭──────────────────────────────────────────────────────────╮
# │ Linux                                                    │
# ╰──────────────────────────────────────────────────────────╯
elif [[ "$OS" == "linux" ]]; then
    echo "📦 Setting up Linux dev environment (user: $USER_NAME)..."

    mkdir -p "$HOME_DIR/.local/bin"
    export PATH="$HOME_DIR/.local/bin:$PATH"

    case "$PKG_MANAGER" in

    # -------------------------------------------------------
    # Atomic Fedora (Bazzite, Silverblue, Kinoite, etc.)
    #
    # Use toolbox for dev tools — keeps the host image clean,
    # no reboot needed, full dnf available inside the container.
    # -------------------------------------------------------
    rpm-ostree)
        CONTAINER_TOOL=$(detect_container_tool)
        CONTAINER_NAME="dev"

        if [[ "$CONTAINER_TOOL" == "none" ]]; then
            echo "❌ Neither toolbox nor distrobox found — skipping."
            echo "   Install one of them and re-run this script."
            exit 1
        fi

        echo "🔵 Atomic Fedora — using $CONTAINER_TOOL for dev tools..."

        # --- Create the container if it doesn't exist ---
        case "$CONTAINER_TOOL" in
        toolbox)
            if ! toolbox list --containers 2>/dev/null | grep -q "$CONTAINER_NAME"; then
                echo "Creating toolbox container '$CONTAINER_NAME'..."
                toolbox create "$CONTAINER_NAME"
            else
                echo "✅ Toolbox container '$CONTAINER_NAME' already exists"
            fi
            ;;
        distrobox)
            if ! distrobox list | grep -q "$CONTAINER_NAME"; then
                # Auto-fix missing subuid/subgid
                if ! grep -q "^$USER_NAME:" /etc/subuid 2>/dev/null ||
                    ! grep -q "^$USER_NAME:" /etc/subgid 2>/dev/null; then
                    echo "⚠️  Missing subuid/subgid — adding entries for $USER_NAME..."
                    sudo usermod --add-subuids 100000-165535 --add-subgids 100000-165535 "$USER_NAME"
                    podman system migrate
                    echo "✅ subuid/subgid added"
                fi

                FEDORA_VERSION=$(rpm -E %fedora 2>/dev/null || echo "latest")
                IMAGE="fedora:$FEDORA_VERSION"

                echo "Pulling container image $IMAGE..."
                if ! podman pull "$IMAGE"; then
                    echo "⚠️  Could not pull $IMAGE, falling back to fedora:latest"
                    IMAGE="fedora:latest"
                    podman pull "$IMAGE"
                fi

                echo "Creating distrobox container '$CONTAINER_NAME' ($IMAGE)..."
                distrobox create --name "$CONTAINER_NAME" --image "$IMAGE"
            else
                echo "✅ Distrobox container '$CONTAINER_NAME' already exists"
            fi
            ;;
        esac

        # --- Install packages inside the container ---
        echo "Installing dev tools inside $CONTAINER_TOOL '$CONTAINER_NAME'..."
        case "$CONTAINER_TOOL" in
        toolbox)
            toolbox run --container "$CONTAINER_NAME" sudo dnf install -y \
                gnupg2 ffmpeg ghostscript ImageMagick \
                luarocks
            ;;
        distrobox)
            distrobox enter --name "$CONTAINER_NAME" -- sudo dnf install -y \
                gnupg2 ffmpeg ghostscript ImageMagick \
                luarocks
            ;;
        esac

        echo "✅ Dev tools installed inside $CONTAINER_TOOL '$CONTAINER_NAME'"
        echo ""
        case "$CONTAINER_TOOL" in
        toolbox)
            echo "💡 Enter the container with:    toolbox enter $CONTAINER_NAME"
            echo "   Run a single command with:   toolbox run --container $CONTAINER_NAME <command>"
            ;;
        distrobox)
            echo "💡 Enter the container with:    distrobox enter $CONTAINER_NAME"
            echo "   Run a single command with:   distrobox enter --name $CONTAINER_NAME -- <command>"
            ;;
        esac
        ;;

    dnf)
        sudo dnf install -y \
            gnupg2 ffmpeg ghostscript ImageMagick \
            luarocks
        ;;

    apt)
        sudo apt update
        sudo apt install -y \
            gnupg ffmpeg ghostscript imagemagick \
            liblua5.1-0-dev luarocks
        ;;

    pacman)
        sudo pacman -S --noconfirm \
            gnupg ffmpeg ghostscript imagemagick \
            luarocks
        ;;

    *)
        echo "❌ Unknown package manager — skipping."
        echo "Please install manually: gnupg, ffmpeg, ghostscript, imagemagick, luarocks"
        exit 1
        ;;
    esac
fi

# ╭──────────────────────────────────────────────────────────╮
# │ Deno                                                     │
# │ curl installer — works on all distros, no reboot needed  │
# ╰──────────────────────────────────────────────────────────╯
if ! command -v "deno" &>/dev/null; then
    curl -fsSL https://deno.land/install.sh | sh
    echo "✅ Installed deno"
else
    echo "✅ Deno already installed"
fi

echo ""
echo "🎉 Dev environment setup complete for $USER_NAME on $OS!"
