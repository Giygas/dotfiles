#!/usr/bin/env bash
# vi:set filetype=sh:

# -------------------------------
# Determine OS and home directory
# -------------------------------
OS="{{ .chezmoi.os }}"
HOME_DIR="{{ .chezmoi.homeDir }}"
USER_NAME=$(whoami)

echo "OS detected: $OS"
echo "User: $USER_NAME"
echo "Home directory: $HOME_DIR"

# -------------------------------
# Detect Linux package manager
# -------------------------------
detect_pkg_manager() {
    if command -v rpm-ostree &>/dev/null; then
        echo "rpm-ostree"
    elif command -v dnf &>/dev/null; then
        echo "dnf"
    elif command -v apt-get &>/dev/null; then
        echo "apt"
    elif command -v pacman &>/dev/null; then
        echo "pacman"
    else
        echo "unknown"
    fi
}

PKG_MANAGER=$(detect_pkg_manager)
echo "Package manager detected: $PKG_MANAGER"

## ╭─────────────────────────────────────────────────────────╮
## │ Initial Setup                                           │
## ╰─────────────────────────────────────────────────────────╯
if [[ "$OS" == "darwin" ]]; then
    echo "📦 Setting up macOS dev environment..."

    if ! xcode-select -p &>/dev/null; then
        echo "Installing Xcode Command Line Tools..."
        xcode-select --install
    fi

    if ! command -v brew &>/dev/null; then
        echo "Installing Homebrew..."
        /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    fi

    echo "Updating homebrew..."
    brew update
    brew install btop
    brew install --cask wezterm

elif [[ "$OS" == "linux" ]]; then
    echo "📦 Setting up Linux dev environment (user: $USER_NAME)..."

    case "$PKG_MANAGER" in

        # -------------------------------------------------------
        # Atomic Fedora (Bazzite, Silverblue, Kinoite, etc.)
        #
        # All host-level packages are installed in a single
        # rpm-ostree call to avoid multiple reboots on first setup:
        #   - zsh: must be on host for chsh/login shell
        #   - wezterm: terminal emulator
        #   - sway + companions: must be on host so SDDM can see
        #     the session file in its login screen picker
        #   - foot: lightweight fallback terminal for Sway with no
        #     desktop environment dependencies
        # -------------------------------------------------------
        rpm-ostree)
            HOST_PACKAGES=(
                zsh
                wezterm
                sway
                swaybg
                swaylock
                swayidle
                waybar
                wmenu
                foot
            )

            # Only install packages not already present
            MISSING_PACKAGES=()
            for pkg in "${HOST_PACKAGES[@]}"; do
                if ! rpm-ostree status | grep -q "$pkg"; then
                    MISSING_PACKAGES+=("$pkg")
                fi
            done

            if [ ${#MISSING_PACKAGES[@]} -ne 0 ]; then
                echo "🔵 Installing host packages via rpm-ostree: ${MISSING_PACKAGES[*]}"
                rpm-ostree install "${MISSING_PACKAGES[@]}"
                echo "⚠️  Reboot required. Re-run chezmoi apply after rebooting to continue setup."
                exit 0
            else
                echo "✅ All host packages already installed"
            fi
            ;;

        dnf)
            sudo dnf install -y zsh wezterm sway swaybg swaylock swayidle waybar wmenu foot
            ;;

        apt)
            sudo apt-get update
            sudo apt-get install -y zsh sway swaybg swaylock swayidle waybar foot
            # wezterm via deb on Ubuntu
            if ! command -v wezterm &>/dev/null; then
                curl -LO https://github.com/wezterm/wezterm/releases/download/nightly/wezterm-nightly.Ubuntu24.04.deb
                sudo apt install -y ./wezterm-nightly.Ubuntu24.04.deb
                rm wezterm-nightly.Ubuntu24.04.deb
            fi
            ;;

        pacman)
            sudo pacman -S --noconfirm zsh wezterm sway swaybg swaylock swayidle waybar wmenu foot
            ;;

        *)
            echo "❌ Unknown package manager — please install zsh, wezterm and sway manually."
            exit 1
            ;;
    esac
fi

# -------------------------------
# Ensure zsh is available before continuing
# -------------------------------
if ! command -v zsh &>/dev/null; then
    echo "❌ zsh is not available yet. Please reboot and re-run chezmoi apply."
    exit 1
fi

echo "✅ zsh available ($(zsh --version))"

# -------------------------------
# Oh My Zsh
# -------------------------------
if [ ! -d "$HOME_DIR/.oh-my-zsh" ]; then
    echo "Installing Oh My Zsh..."
    RUNZSH=no sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended
    echo "✅ Installed Oh My Zsh"
fi

echo "Installing zsh-autosuggestions..."
if [ ! -d "${ZSH_CUSTOM:-$HOME_DIR/.oh-my-zsh/custom}/plugins/zsh-autosuggestions" ]; then
    git clone https://github.com/zsh-users/zsh-autosuggestions "${ZSH_CUSTOM:-$HOME_DIR/.oh-my-zsh/custom}/plugins/zsh-autosuggestions"
fi

echo "Installing zsh-syntax-highlighting..."
if [ ! -d "${ZSH_CUSTOM:-$HOME_DIR/.oh-my-zsh/custom}/plugins/zsh-syntax-highlighting" ]; then
    git clone https://github.com/zsh-users/zsh-syntax-highlighting.git "${ZSH_CUSTOM:-$HOME_DIR/.oh-my-zsh/custom}/plugins/zsh-syntax-highlighting"
fi

# -------------------------------
# Oh My Posh
# -------------------------------
if ! command -v "oh-my-posh" &>/dev/null; then
    if [[ "$OS" == "darwin" ]]; then
        brew install jandedobbeleer/oh-my-posh/oh-my-posh
    elif [[ "$OS" == "linux" ]]; then
        curl -s https://ohmyposh.dev/install.sh | bash -s
    else
        echo "❌ Unsupported OS: $OS"
        exit 1
    fi
    echo "✅ Installed Oh My Posh"
else
    echo "✅ Oh My Posh already installed ($(oh-my-posh --version))"
fi

# ╭──────────────────────────────────────────────────────────╮
# │ Setup .zshrc                                             │
# ╰──────────────────────────────────────────────────────────╯
if [ -f "$HOME_DIR/.zshrc" ]; then

    if ! grep -q "EDITOR=nvim" "$HOME_DIR/.zshrc"; then
        echo 'export EDITOR=nvim' >>"$HOME_DIR/.zshrc"
        echo "✅ Added EDITOR to .zshrc"
    fi

    if ! grep -q ".zsh_aliases" "$HOME_DIR/.zshrc"; then
        echo ". $HOME/.zsh_aliases" >>"$HOME_DIR/.zshrc"
        echo "✅ Added zsh_aliases to .zshrc"
    fi

    if ! grep -q ".zsh_theme" "$HOME_DIR/.zshrc"; then
        echo ". $HOME/.zsh_theme" >>"$HOME_DIR/.zshrc"
        echo "✅ Added zsh_theme to .zshrc"
    fi

    if ! grep -q "zsh-autosuggestions\|zsh-syntax-highlighting" "$HOME_DIR/.zshrc"; then
        if [[ "$OS" == "darwin" ]]; then
            sed -i '' '/^plugins=/ s/)/ zsh-autosuggestions zsh-syntax-highlighting)/' "$HOME_DIR/.zshrc"
        else
            sed -i '/^plugins=/ s/)/ zsh-autosuggestions zsh-syntax-highlighting)/' "$HOME_DIR/.zshrc"
        fi
        echo "✅ Added zsh plugins to .zshrc"
    else
        echo "✅ zsh plugins already present in .zshrc"
    fi

    if [[ "$SHELL" != *"zsh"* ]]; then
        echo "Setting zsh as default shell..."
        if command -v zsh >/dev/null 2>&1; then
            chsh -s "$(command -v zsh)" || echo "󰀪 Could not change shell (may require sudo or different permissions)"
            echo "󰀯 Restart your shell or run 'exec zsh' to use zsh"
        else
            echo "󰀪 zsh is not installed"
        fi
    fi

fi

# ╭──────────────────────────────────────────────────────────╮
# │ Mise setup                                               │
# ╰──────────────────────────────────────────────────────────╯
if ! command -v mise &>/dev/null; then
    echo "Installing mise..."
    curl https://mise.run/zsh | sh
    export PATH="$HOME/.local/bin:$PATH"
    echo "✅ Installed mise"
else
    echo "✅ mise already installed ($(mise --version))"
fi

if command -v mise &>/dev/null; then
    echo "Installing mise tools..."
    mise install
    echo "✅ mise tools installed"
else
    echo "❌ mise not found, skipping tool install"
fi

# ╭──────────────────────────────────────────────────────────╮
# │ Tool integrations (.zshrc)                               │
# ╰──────────────────────────────────────────────────────────╯
# shellcheck disable=SC2016
if ! grep -q 'fzf --zsh' "$HOME_DIR/.zshrc"; then
    echo 'eval "$(fzf --zsh)"' >>"$HOME_DIR/.zshrc"
    echo "✅ Added fzf integration to .zshrc"
fi

# shellcheck disable=SC2016
if ! grep -q 'zoxide init zsh' "$HOME_DIR/.zshrc"; then
    echo 'eval "$(zoxide init zsh)"' >>"$HOME_DIR/.zshrc"
    echo "✅ Added zoxide integration to .zshrc"
fi

# ╭──────────────────────────────────────────────────────────╮
# │ Tmux Plugin Manager                                      │
# ╰──────────────────────────────────────────────────────────╯
if [ ! -d "$HOME_DIR/.tmux/plugins/tpm" ]; then
    echo "Installing Tmux Plugin Manager..."
    git clone https://github.com/tmux-plugins/tpm "$HOME_DIR/.tmux/plugins/tpm"
    echo "✅ Installed TPM"
else
    echo "✅ TPM already installed"
fi

# ╭──────────────────────────────────────────────────────────╮
# │ Fonts                                                    │
# ╰──────────────────────────────────────────────────────────╯
if [[ "$OS" == "darwin" ]]; then
    brew install --cask font-roboto-mono font-jetbrains-mono-nerd-font
elif [[ "$OS" == "linux" ]]; then
    mkdir -p "$HOME/.local/share/fonts"

    if ! fc-list | grep -q "Roboto Mono"; then
        curl -sSL "https://fonts.google.com/download?family=Roboto+Mono" -o /tmp/roboto-mono.zip
        unzip -o /tmp/roboto-mono.zip -d "$HOME/.local/share/fonts/roboto-mono"
        rm /tmp/roboto-mono.zip
        echo "✅ Installed Roboto Mono"
    fi

    if ! fc-list | grep -q "JetBrainsMono"; then
        curl -sSL "https://github.com/ryanoasis/nerd-fonts/releases/latest/download/JetBrainsMono.zip" -o /tmp/jetbrains-nerd.zip
        unzip -o /tmp/jetbrains-nerd.zip -d "$HOME/.local/share/fonts/jetbrains-mono-nerd"
        rm /tmp/jetbrains-nerd.zip
        echo "✅ Installed JetBrains Mono Nerd Font"
    fi

    fc-cache -fv
    echo "✅ Font cache updated"
fi
