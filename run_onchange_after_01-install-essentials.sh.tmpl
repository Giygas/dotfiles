#!/usr/bin/env bash
# vi:set filetype=sh:

# ╭──────────────────────────────────────────────────────────╮
# │ install-essentials                                        │
# │                                                          │
# │ Sets up shell environment, fonts, cursors and theming.   │
# │ Also installs host-level packages on non-atomic systems   │
# │ (atomic systems get their packages from Bootstrap.sh).    │
# │                                                          │
# │ Works on: macOS, Debian/Ubuntu, Fedora, Arch, atomic     │
# ╰──────────────────────────────────────────────────────────╯

OS="{{ .chezmoi.os }}"
HOME_DIR="{{ .chezmoi.homeDir }}"
USER_NAME=$(whoami)

echo "OS detected: $OS"
echo "User: $USER_NAME"
echo "Home directory: $HOME_DIR"

# ╭──────────────────────────────────────────────────────────╮
# │ Package Manager Detection                                 │
# ╰──────────────────────────────────────────────────────────╯

detect_pkg_manager() {
    if command -v rpm-ostree &>/dev/null; then
        echo "rpm-ostree"
    elif command -v dnf &>/dev/null; then
        echo "dnf"
    elif command -v apt-get &>/dev/null; then
        echo "apt"
    elif command -v pacman &>/dev/null; then
        echo "pacman"
    else
        echo "unknown"
    fi
}

PKG_MANAGER=$(detect_pkg_manager)
echo "Package manager detected: $PKG_MANAGER"

# ╭──────────────────────────────────────────────────────────╮
# │ macOS                                                     │
# ╰──────────────────────────────────────────────────────────╯
if [[ "$OS" == "darwin" ]]; then
    if ! xcode-select -p &>/dev/null; then
        echo "Installing Xcode Command Line Tools..."
        xcode-select --install
    fi

    if ! command -v brew &>/dev/null; then
        echo "Installing Homebrew..."
        /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    fi

    brew update
    brew install --cask wezterm 1password
    brew install 1password-cli
    echo "✅ macOS base packages ready"

# ╭──────────────────────────────────────────────────────────╮
# │ Linux                                                     │
# ╰──────────────────────────────────────────────────────────╯
elif [[ "$OS" == "linux" ]]; then

    # Get distro details for package-specific decisions
    LINUX_ID="unknown"
    LINUX_VERSION_ID="unknown"
    if [ -f /etc/os-release ]; then
        # shellcheck disable=SC1091
        eval "$(grep -E '^(ID|VERSION_ID)=' /etc/os-release | sed 's/^/LINUX_/')"
    fi

    echo "Distro: $LINUX_ID $LINUX_VERSION_ID"

    case "$PKG_MANAGER" in

    # -----------------------------------------------------------
    # Atomic Fedora (Bazzite, Silverblue, Kinoite, Sericea, etc.)
    # Host packages installed by Bootstrap.sh before chezmoi ran.
    # -----------------------------------------------------------
    rpm-ostree)
        echo "✅ Atomic Fedora — host packages managed by Bootstrap.sh, skipping"
        ;;

    # -----------------------------------------------------------
    # Fedora (Workstation, Server, etc.)
    # -----------------------------------------------------------
    dnf)
        # --- 1Password repo ---
        if [ ! -f /etc/yum.repos.d/1password.repo ]; then
            echo "Adding 1Password repository..."
            sudo tee /etc/yum.repos.d/1password.repo > /dev/null <<'REPO'
[1password]
name=1Password Stable Channel
baseurl=https://downloads.1password.com/linux/rpm/stable/$basearch
enabled=1
gpgcheck=1
repo_gpgcheck=1
gpgkey=https://downloads.1password.com/linux/keys/1password.asc
REPO
            echo "✅ 1Password repo added"
        fi

        # --- WezTerm COPR ---
        WEZTERM_REPO="/etc/yum.repos.d/_copr:copr.fedorainfracloud.org:wezfurlong:wezterm-nightly.repo"
        if [ ! -f "$WEZTERM_REPO" ]; then
            FEDORA_VER=$(rpm -E %fedora 2>/dev/null || echo "41")
            echo "Adding WezTerm COPR repository..."
            sudo wget -q \
                "https://copr.fedorainfracloud.org/coprs/wezfurlong/wezterm-nightly/repo/fedora-${FEDORA_VER}/wezfurlong-wezterm-nightly-fedora-${FEDORA_VER}.repo" \
                -O "$WEZTERM_REPO"
            echo "✅ WezTerm repo added"
        fi

        sudo dnf install -y zsh wezterm 1password 1password-cli nautilus
        echo "✅ Fedora packages installed"
        ;;

    # -----------------------------------------------------------
    # Debian / Ubuntu
    # -----------------------------------------------------------
    apt)
        sudo apt-get update

        # --- 1Password repo ---
        if ! command -v 1password &>/dev/null; then
            echo "Adding 1Password repository..."
            curl -fsSL https://downloads.1password.com/linux/keys/1password.asc | \
                sudo gpg --yes --dearmor -o /usr/share/keyrings/1password-archive-keyring.gpg
            echo "deb [arch=amd64 signed-by=/usr/share/keyrings/1password-archive-keyring.gpg] https://downloads.1password.com/linux/debian/amd64 stable main" | \
                sudo tee /etc/apt/sources.list.d/1password.list > /dev/null
            sudo apt-get update
        fi

        sudo apt-get install -y zsh 1password 1password-cli nautilus

        # --- WezTerm ---
        if ! command -v wezterm &>/dev/null; then
            WEZTERM_DEB=""
            case "$LINUX_ID" in
                ubuntu)
                    WEZTERM_DEB="wezterm-nightly.Ubuntu${LINUX_VERSION_ID}.deb"
                    ;;
                *)
                    # Debian and others — try Ubuntu 22.04 deb (widely compatible)
                    WEZTERM_DEB="wezterm-nightly.Ubuntu22.04.deb"
                    ;;
            esac

            echo "Downloading WezTerm (${WEZTERM_DEB})..."
            if curl -fLO "https://github.com/wezterm/wezterm/releases/download/nightly/${WEZTERM_DEB}"; then
                sudo apt-get install -y "./${WEZTERM_DEB}"
                rm -f "$WEZTERM_DEB"
                echo "✅ WezTerm installed"
            else
                rm -f "$WEZTERM_DEB" 2>/dev/null
                echo "⚠️  Could not download WezTerm deb."
                echo "   Install manually: https://wezfurlong.org/wezterm/install/linux.html"
            fi
        fi

        echo "✅ Debian/Ubuntu packages installed"
        ;;

    # -----------------------------------------------------------
    # Arch / Manjaro / EndeavourOS
    # -----------------------------------------------------------
    pacman)
        # wezterm and zsh are in official repos
        sudo pacman -S --noconfirm --needed zsh wezterm nautilus

        # 1Password: only in AUR, not installable via pacman directly
        if ! command -v 1password &>/dev/null; then
            echo ""
            echo "⚠️  1Password is only available in the AUR."
            echo "   Install with your AUR helper, e.g.:"
            echo "     yay -S 1password 1password-cli"
            echo "     paru -S 1password 1password-cli"
            echo ""
        fi

        echo "✅ Arch packages installed"
        ;;

    *)
        echo "⚠️  Unknown package manager — skipping host packages."
        echo "   Please install manually: zsh, wezterm, 1password, 1password-cli, nautilus"
        ;;
    esac

    # ╭──────────────────────────────────────────────────────────╮
    # │ Hyprland (Linux, non-atomic)                             │
    # ╰──────────────────────────────────────────────────────────╯

    # Skip on atomic — Bootstrap.sh already handled it
    if [[ "$PKG_MANAGER" != "rpm-ostree" ]]; then
        echo ""
        echo "--- Hyprland Window Manager ---"

        if command -v hyprland &>/dev/null; then
            echo "✅ Hyprland already installed"
        else
            echo "Do you want to install Hyprland window manager? (y/n)"
            printf "→ "
            read -n 1 -r HYPRL_RESP
            echo ""

            if [[ "$HYPRL_RESP" =~ ^[yY]$ ]]; then
                case "$PKG_MANAGER" in

                # Fedora — COPR repos + dnf
                dnf)
                    FEDORA_VER=$(rpm -E %fedora 2>/dev/null || echo "41")

                    HYPRLAND_REPO="/etc/yum.repos.d/solopasha-hyprland-fedora.repo"
                    if [ ! -f "$HYPRLAND_REPO" ]; then
                        echo "Adding Hyprland COPR repository..."
                        sudo wget -q \
                            "https://copr.fedorainfracloud.org/coprs/solopasha/hyprland/repo/fedora-${FEDORA_VER}/solopasha-hyprland-fedora-${FEDORA_VER}.repo" \
                            -O "$HYPRLAND_REPO"
                        echo "✅ Hyprland repo added"
                    fi

                    SWAYNC_REPO="/etc/yum.repos.d/_copr:copr.fedorainfracloud.org:erikreider:SwayNotificationCenter.repo"
                    if [ ! -f "$SWAYNC_REPO" ]; then
                        echo "Adding SwayNotificationCenter COPR repository..."
                        sudo wget -q \
                            "https://copr.fedorainfracloud.org/coprs/erikreider/SwayNotificationCenter/repo/fedora-${FEDORA_VER}/erikreider-SwayNotificationCenter-fedora-${FEDORA_VER}.repo" \
                            -O "$SWAYNC_REPO"
                        echo "✅ SwayNotificationCenter repo added"
                    fi

                    sudo dnf install -y \
                        hyprland hyprlock hypridle hyprpaper \
                        wlogout waybar rofi foot blueman \
                        xdg-desktop-portal-hyprland \
                        SwayNotificationCenter
                    echo "✅ Hyprland installed via dnf"
                    ;;

                # Arch — all in official repos
                pacman)
                    sudo pacman -S --noconfirm --needed \
                        hyprland hyprlock hypridle hyprpaper \
                        wlogout waybar rofi foot blueman \
                        xdg-desktop-portal-hyprland \
                        swaync
                    echo "✅ Hyprland installed via pacman"
                    ;;

                # Debian/Ubuntu — too fragmented to automate
                apt)
                    echo ""
                    echo "⚠️  Hyprland is not available in Debian/Ubuntu repos."
                    echo "   Options:"
                    echo "     Ubuntu — PPA: https://github.com/Ja-KooList/Hyprland-PPA"
                    echo "     Debian — build from source: https://wiki.hyprland.org/Nix/"
                    echo ""
                    ;;
                esac
            fi
        fi
    fi
fi

# ╭──────────────────────────────────────────────────────────╮
# │ Zsh Plugins                                               │
# ╰──────────────────────────────────────────────────────────╯

echo ""
echo "--- Shell Setup ---"

ZSH_PLUGINS="$HOME_DIR/.zsh/plugins"
mkdir -p "$ZSH_PLUGINS"

echo "Installing zsh-autosuggestions..."
if [ ! -d "$ZSH_PLUGINS/zsh-autosuggestions" ]; then
    git clone https://github.com/zsh-users/zsh-autosuggestions "$ZSH_PLUGINS/zsh-autosuggestions"
else
    echo "✅ zsh-autosuggestions already installed"
fi

echo "Installing zsh-syntax-highlighting..."
if [ ! -d "$ZSH_PLUGINS/zsh-syntax-highlighting" ]; then
    git clone https://github.com/zsh-users/zsh-syntax-highlighting "$ZSH_PLUGINS/zsh-syntax-highlighting"
else
    echo "✅ zsh-syntax-highlighting already installed"
fi

# ╭──────────────────────────────────────────────────────────╮
# │ Oh My Posh                                                │
# ╰──────────────────────────────────────────────────────────╯

if ! command -v "oh-my-posh" &>/dev/null; then
    if [[ "$OS" == "darwin" ]]; then
        brew install jandedobbeleer/oh-my-posh/oh-my-posh
    elif [[ "$OS" == "linux" ]]; then
        curl -s https://ohmyposh.dev/install.sh | bash -s
    else
        echo "❌ Unsupported OS: $OS"
        exit 1
    fi
    echo "✅ Installed Oh My Posh"
else
    echo "✅ Oh My Posh already installed ($(oh-my-posh --version))"
fi

# ╭──────────────────────────────────────────────────────────╮
# │ Mise                                                      │
# │ Installs to ~/.local/bin — no package manager needed      │
# ╰──────────────────────────────────────────────────────────╯

if ! command -v "$HOME/.local/bin/mise" &>/dev/null; then
    echo "Installing mise..."
    curl https://mise.run | sh
    export PATH="$HOME/.local/bin:$PATH"
    echo "✅ Installed mise"
else
    echo "✅ mise already installed ($("$HOME/.local/bin/mise" --version))"
fi

if command -v mise &>/dev/null; then
    echo "Installing mise tools..."
    mise install
    echo "✅ mise tools installed"
else
    echo "❌ mise not found after install — check ~/.local/bin is in PATH"
fi

# ╭──────────────────────────────────────────────────────────╮
# │ Set default shell to zsh                                  │
# ╰──────────────────────────────────────────────────────────╯

if [[ "$SHELL" != *"zsh"* ]]; then
    if command -v zsh >/dev/null 2>&1; then
        echo "Setting zsh as default shell..."
        if command -v usermod >/dev/null 2>&1; then
            sudo usermod --shell "$(which zsh)" "$USER_NAME"
        elif command -v chsh >/dev/null 2>&1; then
            chsh -s "$(which zsh)"
        else
            echo "⚠️  Neither usermod nor chsh found — run manually:"
            echo "   sudo usermod --shell \$(which zsh) \$USER"
        fi
        echo "✅ Default shell set to zsh — log out and back in to apply"
    else
        echo "⚠️  Skipping shell change — zsh not available yet."
    fi
fi

# ╭──────────────────────────────────────────────────────────╮
# │ Tmux Plugin Manager                                       │
# ╰──────────────────────────────────────────────────────────╯

echo ""
echo "--- Tmux ---"

TPM_PATH="${HOME_DIR}/.tmux/plugins/tpm"
if [ ! -d "$TPM_PATH" ]; then
    echo "Installing Tmux Plugin Manager..."
    git clone https://github.com/tmux-plugins/tpm "$TPM_PATH"
    echo "✅ Installed TPM"
else
    echo "✅ TPM already installed"
fi

# Install plugins (this can run even if tmux server isn't started)
echo "Installing tmux plugins..."
"$TPM_PATH/bin/install_plugins"

# ╭──────────────────────────────────────────────────────────╮
# │ Fonts (Linux only)                                        │
# ╰──────────────────────────────────────────────────────────╯

echo ""
echo "--- Fonts ---"

if [[ "$OS" == "linux" ]]; then
    mkdir -p "$HOME/.local/share/fonts"

    if ! fc-list | grep -q "RobotoMono"; then
        curl -sSL "https://github.com/ryanoasis/nerd-fonts/releases/latest/download/RobotoMono.zip" \
            -o /tmp/roboto-mono.zip
        unzip -o /tmp/roboto-mono.zip -d "$HOME/.local/share/fonts/roboto-mono"
        rm /tmp/roboto-mono.zip
        echo "✅ Installed RobotoMono Nerd Font"
    else
        echo "✅ RobotoMono Nerd Font already installed"
    fi

    if ! fc-list | grep -q "JetBrainsMono"; then
        curl -sSL "https://github.com/ryanoasis/nerd-fonts/releases/latest/download/JetBrainsMono.zip" \
            -o /tmp/jetbrains-nerd.zip
        unzip -o /tmp/jetbrains-nerd.zip -d "$HOME/.local/share/fonts/jetbrains-mono-nerd"
        rm /tmp/jetbrains-nerd.zip
        echo "✅ Installed JetBrains Mono Nerd Font"
    else
        echo "✅ JetBrains Mono Nerd Font already installed"
    fi

    if ! fc-list | grep -q "Fira Sans"; then
        mkdir -p "$HOME/.local/share/fonts/fira-sans"
        curl -sSL "https://github.com/mozilla/Fira/archive/refs/heads/master.zip" \
            -o /tmp/fira-sans.zip
        unzip -o /tmp/fira-sans.zip "*/ttf/*" -d /tmp/fira-sans-extract
        find /tmp/fira-sans-extract -name "*.ttf" -exec mv {} "$HOME/.local/share/fonts/fira-sans/" \;
        rm -rf /tmp/fira-sans.zip /tmp/fira-sans-extract
        echo "✅ Installed Fira Sans"
    else
        echo "✅ Fira Sans already installed"
    fi

    fc-cache -fv
    echo "✅ Font cache updated"
else
    echo "✅ Fonts managed by Homebrew on macOS"
fi

# ╭──────────────────────────────────────────────────────────╮
# │ Cursors (Linux only)                                      │
# │ Bibata Modern Classic                                     │
# ╰──────────────────────────────────────────────────────────╯

echo ""
echo "--- Cursors ---"

if [[ "$OS" == "linux" ]]; then
    mkdir -p "$HOME/.local/share/icons"
    if [ ! -d "$HOME/.local/share/icons/Bibata-Modern-Classic" ]; then
        echo "Installing Bibata Modern Classic cursor theme..."
        DOWNLOAD_URL=$(curl -s https://api.github.com/repos/ful1e5/Bibata_Cursor/releases/latest |
            grep "browser_download_url.*Bibata-Modern-Classic\.tar\.xz\"" |
            grep -v "Right" |
            head -1 |
            cut -d '"' -f 4)
        curl -fL "$DOWNLOAD_URL" | tar -xJ -C "$HOME/.local/share/icons/"
        echo "✅ Installed Bibata Modern Classic cursors"
    else
        echo "✅ Bibata Modern Classic cursors already installed"
    fi
else
    echo "✅ Cursors not applicable on macOS"
fi

# ╭──────────────────────────────────────────────────────────╮
# │ Wallust (Linux only)                                      │
# │ Color scheme generator from wallpapers                    │
# ╰──────────────────────────────────────────────────────────╯

echo ""
echo "--- Color Theming ---"

if [[ "$OS" == "linux" ]]; then
    if ! command -v wallust &>/dev/null; then
        echo "Installing wallust..."
        if command -v cargo &>/dev/null; then
            cargo install wallust
            echo "✅ Installed wallust via cargo"
        else
            echo "⚠️  cargo not found — skipping wallust."
            echo "   Install Rust first (https://rustup.rs) then: cargo install wallust"
        fi
    else
        echo "✅ wallust already installed"
    fi
else
    echo "✅ wallust not applicable on macOS"
fi

echo ""
echo "🎉 Essentials setup complete for $USER_NAME on $OS!"
