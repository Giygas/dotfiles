{%- set obr = '{{' %}
{%- set cbr = '}}' %}
{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "segments": [
        {
          "foreground": "{{ color2 }}",
          "style": "diamond",
          "template": "{{ obr }} round .PhysicalPercentUsed .Precision {{ cbr }}%",
          "type": "sysinfo"
        },
        {
          "foreground": "{{ color2 }}",
          "style": "diamond",
          "template": "{{ obr }} (div ((sub .PhysicalTotalMemory .PhysicalAvailableMemory)|float64) 1073741824.0) {{ cbr }}/{{ obr }} (div .PhysicalTotalMemory 1073741824.0) {{ cbr }}GB ",
          "type": "sysinfo"
        }
      ],
      "type": "rprompt"
    },
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "{{ color2 }}",
          "options": {
            "macos": "mac"
          },
          "style": "plain",
          "template": "{{ obr }} if .WSL {{ cbr }}WSL at {{ obr }} end {{ cbr }}{{ obr }}.Icon{{ cbr }} ",
          "type": "os"
        },
        {
          "foreground": "{{ color4 }}",
          "style": "plain",
          "template": "in {{ obr }} .Value {{ cbr }} ",
          "type": "envvar",
          "properties": {
            "var": "DISTROBOX_NAME"
          }
        },
        {
          "foreground": "{{ color2 }}",
          "style": "plain",
          "template": "$",
          "type": "text"
        },
        {
          "foreground": "{{ color2 }}",
          "style": "plain",
          "template": "{{ obr }} .UserName {{ cbr }}:",
          "type": "session"
        },
        {
          "foreground": "{{ foreground }}",
          "options": {
            "folder_separator_icon": "/",
            "style": "full"
          },
          "style": "plain",
          "type": "path"
        },
        {
          "foreground": "{{ color2 }}",
          "foreground_templates": [
            "{{ obr }} if or (.Working.Changed) (.Staging.Changed) {{ cbr }}{{ color1 }}{{ obr }} end {{ cbr }}",
            "{{ obr }} if and (gt .Ahead 0) (gt .Behind 0) {{ cbr }}{{ color4 }}{{ obr }} end {{ cbr }}",
            "{{ obr }} if gt .Ahead 0 {{ cbr }}{{ color6 }}{{ obr }} end {{ cbr }}",
            "{{ obr }} if gt .Behind 0 {{ cbr }}{{ color1 }}{{ obr }} end {{ cbr }}"
          ],
          "options": {
            "branch_template": "{{ obr }} trunc 25 .Branch {{ cbr }}",
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "style": "plain",
          "template": "<{{ color1 }}>on</> {{ obr }}.UpstreamIcon {{ cbr }}{{ obr }} .HEAD {{ cbr }}{{ obr }}if .BranchStatus {{ cbr }} {{ obr }} .BranchStatus {{ cbr }}{{ obr }} end {{ cbr }}{{ obr }} if .Working.Changed {{ cbr }} \uf044 {{ obr }} .Working.String {{ cbr }}{{ obr }} end {{ cbr }}{{ obr }} if and (.Working.Changed) (.Staging.Changed) {{ cbr }} |{{ obr }} end {{ cbr }}{{ obr }} if .Staging.Changed {{ cbr }} \uf046 {{ obr }} .Staging.String {{ cbr }}{{ obr }} end {{ cbr }}{{ obr }} if gt .StashCount 0 {{ cbr }} \ueb4b {{ obr }} .StashCount {{ cbr }}{{ obr }} end {{ cbr }} ",
          "type": "git"
        },
        {
          "foreground": "{{ color1 }}",
          "style": "plain",
          "template": "\u276f ",
          "type": "text"
        }
      ],
      "type": "prompt"
    }
  ],
  "version": 4
}
