general {
    lock_cmd = pidof hyprlock || hyprlock
    before_sleep_cmd = loginctl lock-session
    after_sleep_cmd = hyprctl dispatch dpms on
}

# Lock after 5 minutes
listener {
    timeout = 300
    on-timeout = pidof hyprlock || hyprlock
}

# Screen off after 10 minutes (kill waybar and hyprlock before DPMS, restart on resume)
listener {
    timeout = 600
    on-timeout = pkill -x waybar; pkill -x hyprlock; hyprctl dispatch dpms off
    on-resume = hyprlock & waybar &
}

# Suspend after 15 minutes
listener {
    timeout = 900
    on-timeout = systemctl suspend
}
