
{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "segments": [
        {
          "foreground": "#865CC5",
          "style": "diamond",
          "template": "{{ round .PhysicalPercentUsed .Precision }}%",
          "type": "sysinfo"
        },
        {
          "foreground": "#865CC5",
          "style": "diamond",
          "template": "{{ (div ((sub .PhysicalTotalMemory .PhysicalAvailableMemory)|float64) 1073741824.0) }}/{{ (div .PhysicalTotalMemory 1073741824.0) }}GB ",
          "type": "sysinfo"
        }
      ],
      "type": "rprompt"
    },
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "#8658C2",
          "options": {
            "macos": "mac"
          },
          "style": "plain",
          "template": "{{ if .WSL }}WSL at {{ end }}{{.Icon}} ",
          "type": "os"
        },
        {
          "foreground": "#6378AD",
          "style": "plain",
          "template": "in {{ .Value }} ",
          "type": "envvar",
          "properties": {
            "var": "DISTROBOX_NAME"
          }
        },
        {
          "foreground": "#8658C2",
          "style": "plain",
          "template": "$",
          "type": "text"
        },
        {
          "foreground": "#8658C2",
          "style": "plain",
          "template": "{{ .UserName }}:",
          "type": "session"
        },
        {
          "foreground": "#827297",
          "options": {
            "folder_separator_icon": "/",
            "style": "full"
          },
          "style": "plain",
          "type": "path"
        },
        {
          "foreground": "#8658C2",
          "foreground_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#614793{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#84A1E7{{ end }}",
            "{{ if gt .Ahead 0 }}#865CC5{{ end }}",
            "{{ if gt .Behind 0 }}#614793{{ end }}"
          ],
          "options": {
            "branch_template": "{{ trunc 25 .Branch }}",
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "style": "plain",
          "template": "<#84A1E7>on</> {{.UpstreamIcon }}{{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} \ueb4b {{ .StashCount }}{{ end }} ",
          "type": "git"
        },
        {
          "foreground": "#84A1E7",
          "style": "plain",
          "template": "\u276f ",
          "type": "text"
        }
      ],
      "type": "prompt"
    }
  ],
  "version": 4
}
