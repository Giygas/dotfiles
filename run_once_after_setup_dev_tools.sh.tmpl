#!/usr/bin/env bash
# vi:set filetype=sh:

# Note: most dev tools (fd, fzf, zoxide, ripgrep, neovim, lazygit,
# btop, yazi, shellcheck, shfmt, pandoc, etc.) are managed by mise.
# This script only installs packages that mise does not cover.

# Interactive prompt function
ask_install_dev_tools() {
    printf "Do you want to install development tools? (y/n) "
    read -n 1 -r response
    echo
    if [[ "$response" =~ ^([yY])$ ]]; then
        echo "Installing dev tools..."
        return 0
    else
        echo "Skipping dev tools installation."
        return 1
    fi
}

# -------------------------------
# Determine OS and home directory
# -------------------------------
OS="{{ .chezmoi.os }}"
HOME_DIR="{{ .chezmoi.homeDir }}"
USER_NAME=$(whoami)

echo "OS detected: $OS"
echo "User: $USER_NAME"
echo "Home directory: $HOME_DIR"

# -------------------------------
# Detect Linux package manager
# -------------------------------
detect_pkg_manager() {
    if command -v rpm-ostree &>/dev/null; then
        echo "rpm-ostree"
    elif command -v dnf &>/dev/null; then
        echo "dnf"
    elif command -v apt-get &>/dev/null; then
        echo "apt"
    elif command -v pacman &>/dev/null; then
        echo "pacman"
    else
        echo "unknown"
    fi
}

PKG_MANAGER=$(detect_pkg_manager)
echo "Package manager detected: $PKG_MANAGER"

# -------------------------------
# Per OS setup
# -------------------------------
if ask_install_dev_tools; then
    echo "🔧 Starting dev environment setup..."

    # ╭──────────────────────────────────────────────────────────╮
    # │ macOS                                                    │
    # ╰──────────────────────────────────────────────────────────╯
    if [[ "$OS" == "darwin" ]]; then
        echo "📦 Setting up macOS dev environment..."

        if ! command -v brew &>/dev/null; then
            echo "Installing Homebrew..."
            /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
        fi

        echo "Installing Homebrew packages..."
        brew install \
            cocoapods colima docker \
            ffmpeg ghostscript imagemagick \
            git-filter-repo gnupg icu4c@76 \
            mongosh pinentry-mac plow \
            watchman wrk luarocks

    # ╭──────────────────────────────────────────────────────────╮
    # │ Linux                                                    │
    # ╰──────────────────────────────────────────────────────────╯
    elif [[ "$OS" == "linux" ]]; then
        echo "📦 Setting up Linux dev environment (user: $USER_NAME)..."

        mkdir -p "$HOME_DIR/.local/bin"
        export PATH="$HOME_DIR/.local/bin:$PATH"

        case "$PKG_MANAGER" in

            # -------------------------------------------------------
            # Atomic Fedora (Bazzite, Silverblue, Kinoite, etc.)
            #
            # Use toolbox for dev tools — keeps the host image clean,
            # no reboot needed, full dnf available inside the container.
            # -------------------------------------------------------
            rpm-ostree)
                echo "🔵 Atomic Fedora detected — using toolbox for dev tools..."

                TOOLBOX_NAME="dev"

                if ! toolbox list --containers | grep -q "^$TOOLBOX_NAME$"; then
                    echo "Creating toolbox container '$TOOLBOX_NAME'..."
                    toolbox create "$TOOLBOX_NAME"
                    echo "✅ Toolbox container '$TOOLBOX_NAME' created"
                else
                    echo "✅ Toolbox container '$TOOLBOX_NAME' already exists"
                fi

                echo "Installing dev tools inside toolbox '$TOOLBOX_NAME'..."
                toolbox run --container "$TOOLBOX_NAME" sudo dnf install -y \
                    gnupg2 \
                    ffmpeg \
                    ghostscript \
                    ImageMagick \
                    luarocks \
                    watchman \
                    git-filter-repo

                echo "✅ Dev tools installed inside toolbox '$TOOLBOX_NAME'"
                echo ""
                echo "💡 Enter the container with:        toolbox enter $TOOLBOX_NAME"
                echo "   Run a single command with:       toolbox run --container $TOOLBOX_NAME <command>"
                ;;

            # -------------------------------------------------------
            # Standard Fedora / RHEL
            # -------------------------------------------------------
            dnf)
                echo "🔵 Fedora/RHEL detected — using dnf..."
                sudo dnf install -y \
                    gnupg2 \
                    ffmpeg \
                    ghostscript \
                    ImageMagick \
                    luarocks \
                    watchman \
                    git-filter-repo
                ;;

            # -------------------------------------------------------
            # Debian / Ubuntu
            # -------------------------------------------------------
            apt)
                echo "🔵 Debian/Ubuntu detected — using apt..."
                sudo apt update
                sudo apt install -y \
                    gnupg \
                    ffmpeg \
                    ghostscript \
                    imagemagick \
                    liblua5.1-0-dev \
                    luarocks \
                    watchman \
                    git-filter-repo
                ;;

            # -------------------------------------------------------
            # Arch
            # -------------------------------------------------------
            pacman)
                echo "🔵 Arch detected — using pacman..."
                sudo pacman -S --noconfirm \
                    gnupg \
                    ffmpeg \
                    ghostscript \
                    imagemagick \
                    luarocks \
                    watchman \
                    git-filter-repo
                ;;

            *)
                echo "❌ Unknown package manager — skipping system package install."
                echo "Please install manually: gnupg, ffmpeg, ghostscript, imagemagick, luarocks, watchman, git-filter-repo"
                ;;
        esac
    fi
else
    echo "⏭️  Skipping dev tools installation"
fi

# ╭──────────────────────────────────────────────────────────╮
# │ Deno (curl installer — works on all distros, no reboot)  │
# ╰──────────────────────────────────────────────────────────╯
if ! command -v "deno" &>/dev/null; then
    curl -fsSL https://deno.land/install.sh | sh
    echo "✅ Installed deno"
else
    echo "✅ Deno already installed"
fi

echo "🎉 Dev environment setup complete for $USER_NAME on $OS!"
