.config/nvim/lazy-lock.json

# Git directories and files (recursive)
**/.git
**/.gitignore
**/.gitattributes
**/.gitmodules

**/opencode/package*.json
**/opencode/bun.lock
**/node_modules

# tmux plugins
*/tmux/plugins/*
!*/tmux/plugins/tmux-sessionx


# OS-specific files
**/.DS_Store
**/Thumbs.db

# Editor files
**/.vscode
**/.idea
**/*.swp
**/*.swo
**/*~

# MacOS only files
{{ if ne .chezmoi.os "darwin" }}
.aerospace.toml
{{ end }}

# Linux only files
{{ if ne .chezmoi.os "linux" }}
.config/hypr/
.config/waybar/
.config/wlogout/
.config/xdg-desktop-portal/
.config/wal/
.config/wallust/
.config/rofi/
.config/swaync/
.config/cava/
.config/rmpc/
.config/mpd/
.local/share/sddm-themes/
{{ end }}
